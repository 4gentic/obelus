{
  "name": "@obelus/bundle-schema",
  "version": "0.1.0",
  "description": "The review-bundle contract shared by the Obelus web app and the Claude Code plugin.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./json-schema/v1": "./schemas/bundle-v1.schema.json",
    "./json-schema/v2": "./schemas/bundle-v2.schema.json"
  },
  "files": [
    "dist",
    "schemas",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/emit-json-schema.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "vitest": "4.1.4"
  }
}
