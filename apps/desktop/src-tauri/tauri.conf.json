{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Obelus",
  "version": "0.1.8",
  "identifier": "app.obelus.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "beforeBuildCommand": "pnpm build:vite",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Obelus",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost tauri: https://tauri.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Offline review surface for AI-assisted papers.",
    "longDescription": "Obelus reviews AI-assisted papers on-device and hands Claude Code a file to apply.",
    "copyright": "",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../packages/claude-plugin/skills": "plugin/skills",
      "../../../packages/claude-plugin/agents": "plugin/agents",
      "../../../packages/claude-plugin/schemas": "plugin/schemas",
      "../../../packages/claude-plugin/.claude-plugin": "plugin/.claude-plugin"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/4gentic/obelus/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxNDJDMDBFREE3ODBDMApSV1RBZ0tmdEFDd1VCMEczdFJRZDZzalI3bG9VTWtMbUI5dCtEWW5tUmNTQnZCUDJLbkhzM3FwMQo="
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "obelus"
        ]
      }
    }
  }
}
