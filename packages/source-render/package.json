{
  "name": "@obelus/source-render",
  "version": "0.1.0",
  "description": "Desktop-only renderers (markdown, LaTeX, typst) that emit HTML carrying data-src-file/line/col so a Selection in the preview resolves to a SourceAnchor.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "demo": "tsx scripts/render-demo.ts"
  },
  "dependencies": {
    "hast-util-from-html": "2.0.3",
    "hast-util-to-html": "9.0.5",
    "mdast-util-from-markdown": "2.0.3",
    "mdast-util-gfm": "3.1.0",
    "mdast-util-to-hast": "13.2.1",
    "micromark-extension-gfm": "3.0.0",
    "unist-util-visit": "5.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@obelus/anchor": "workspace:*",
    "@types/hast": "3.0.4",
    "@types/mdast": "4.0.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "happy-dom": "20.9.0",
    "react": "19.2.5",
    "tsx": "4.21.0",
    "vitest": "4.1.4"
  }
}
