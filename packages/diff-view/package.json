{
  "name": "@obelus/diff-view",
  "version": "0.1.0",
  "description": "Pure presentational React component that paints unified-diff hunks with Obelus's editorial styling. Props only — no stores, no IPC, no router, no @obelus/repo dependency.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./diff-view.css": "./src/diff-view.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "react": "19.2.6",
    "vitest": "4.1.6"
  }
}
