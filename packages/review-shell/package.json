{
  "name": "@obelus/review-shell",
  "version": "0.1.0",
  "description": "Three-column review shell: document · margin gutter · review pane. Consumes a DocumentView adapter so PDF, Markdown, and HTML surfaces share one layout, one margin-note stacker, and one marks pane.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./review-shell.css": "./src/review-shell.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@obelus/bundle-schema": "workspace:*",
    "@obelus/categories": "workspace:*",
    "@obelus/repo": "workspace:*",
    "@obelus/review-store": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "happy-dom": "20.9.0",
    "react": "19.2.5",
    "vitest": "4.1.4"
  }
}
