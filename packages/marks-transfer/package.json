{
  "name": "@obelus/marks-transfer",
  "version": "0.1.0",
  "description": "Pure build/import logic for portable review-marks archives. Shared by the web app and the desktop app; no React or pdfjs dependency.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@obelus/bundle-schema": "workspace:*",
    "@obelus/categories": "workspace:*",
    "@obelus/repo": "workspace:*"
  },
  "devDependencies": {
    "vitest": "4.1.6"
  }
}
