{
  "name": "@obelus/bundle-builder",
  "version": "0.1.0",
  "description": "Pure bundle serialization: take already-fetched paper/revision/annotations and produce a parsed BundleV1. Shared by the web app and the desktop app.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@obelus/bundle-schema": "workspace:*",
    "@obelus/prompts": "workspace:*"
  },
  "devDependencies": {
    "vitest": "4.1.4"
  }
}
