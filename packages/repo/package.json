{
  "name": "@obelus/repo",
  "version": "0.1.0",
  "description": "Storage repository interface for Obelus: shared types + Dexie+OPFS web impl + Tauri SQLite desktop impl.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./web": {
      "types": "./src/web/index.ts",
      "import": "./src/web/index.ts"
    },
    "./sqlite": {
      "types": "./src/sqlite/index.ts",
      "import": "./src/sqlite/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@obelus/bundle-schema": "workspace:*",
    "dexie": "4.4.2",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-sql": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@tauri-apps/api": {
      "optional": true
    },
    "@tauri-apps/plugin-sql": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-sql": "2.4.0",
    "happy-dom": "20.9.0",
    "vitest": "4.1.5"
  }
}
