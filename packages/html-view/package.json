{
  "name": "@obelus/html-view",
  "version": "0.1.0",
  "description": "React component that renders an HTML paper into Obelus's review surface. Sanitizes via DOMPurify, mounts inside a Shadow DOM, and dispatches selections to either a SourceAnchor (paired-source HTML carrying data-src-* markers) or an HtmlAnchor (hand-authored HTML).",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./shadow-shim.css": "./src/shadow-shim.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@obelus/anchor": "workspace:*",
    "@obelus/bundle-schema": "workspace:*",
    "@obelus/repo": "workspace:*",
    "@obelus/review-shell": "workspace:*",
    "@obelus/review-store": "workspace:*",
    "@obelus/source-render": "workspace:*",
    "dompurify": "3.4.1"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "happy-dom": "20.9.0",
    "react": "19.2.5",
    "vitest": "4.1.4"
  }
}
