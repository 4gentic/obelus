{
  "name": "@obelus/prompts",
  "version": "0.1.0",
  "description": "Single source of truth for every reviewer/writer instruction text. Pure TS, no I/O. Consumed by web, desktop, plugin SKILL render.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "4.1.4"
  }
}
