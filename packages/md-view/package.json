{
  "name": "@obelus/md-view",
  "version": "0.1.0",
  "description": "React component that renders a markdown paper into Obelus's review surface. Calls renderMarkdown (pure JS, browser-safe) and paints the HTML with data-src-* attributes intact so selection → SourceAnchor works.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./md.css": "./src/md.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@obelus/anchor": "workspace:*",
    "@obelus/source-render": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "react": "19.2.5",
    "vitest": "4.1.4"
  }
}
