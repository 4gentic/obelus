{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "bundleVersion": {
      "type": "string",
      "const": "1.0"
    },
    "tool": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "obelus"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "additionalProperties": false
    },
    "project": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "writer",
            "reviewer"
          ]
        },
        "categories": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "slug": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$"
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "color": {
                "type": "string"
              }
            },
            "required": [
              "slug",
              "label"
            ],
            "additionalProperties": false
          }
        },
        "main": {
          "type": "string",
          "minLength": 1
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "relPath": {
                "type": "string",
                "minLength": 1
              },
              "format": {
                "type": "string",
                "enum": [
                  "tex",
                  "md",
                  "typ",
                  "bib",
                  "cls",
                  "sty",
                  "bst",
                  "pdf",
                  "yml",
                  "json",
                  "txt",
                  "other"
                ]
              },
              "role": {
                "type": "string",
                "enum": [
                  "main",
                  "include",
                  "bib",
                  "asset"
                ]
              }
            },
            "required": [
              "relPath",
              "format"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "id",
        "label",
        "kind",
        "categories"
      ],
      "additionalProperties": false
    },
    "papers": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          },
          "title": {
            "type": "string"
          },
          "revision": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
          },
          "pdf": {
            "type": "object",
            "properties": {
              "relPath": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "pageCount": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "relPath",
              "sha256",
              "pageCount"
            ],
            "additionalProperties": false
          },
          "entrypoint": {
            "type": "string",
            "minLength": 1
          },
          "rubric": {
            "type": "object",
            "properties": {
              "body": {
                "type": "string"
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "enum": [
                  "file",
                  "paste",
                  "inline"
                ]
              }
            },
            "required": [
              "body",
              "label",
              "source"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "id",
          "title",
          "revision",
          "createdAt"
        ],
        "additionalProperties": false
      }
    },
    "annotations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          },
          "paperId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "quote": {
            "type": "string",
            "minLength": 1
          },
          "contextBefore": {
            "type": "string"
          },
          "contextAfter": {
            "type": "string"
          },
          "anchor": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "pdf"
                  },
                  "page": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "bbox": {
                    "type": "array",
                    "prefixItems": [
                      {
                        "type": "number"
                      },
                      {
                        "type": "number"
                      },
                      {
                        "type": "number"
                      },
                      {
                        "type": "number"
                      }
                    ]
                  },
                  "textItemRange": {
                    "type": "object",
                    "properties": {
                      "start": {
                        "type": "array",
                        "prefixItems": [
                          {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          },
                          {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          }
                        ]
                      },
                      "end": {
                        "type": "array",
                        "prefixItems": [
                          {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          },
                          {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          }
                        ]
                      }
                    },
                    "required": [
                      "start",
                      "end"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "kind",
                  "page",
                  "bbox",
                  "textItemRange"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "source"
                  },
                  "file": {
                    "type": "string",
                    "minLength": 1
                  },
                  "lineStart": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "colStart": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "lineEnd": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "colEnd": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": [
                  "kind",
                  "file",
                  "lineStart",
                  "colStart",
                  "lineEnd",
                  "colEnd"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "html"
                  },
                  "file": {
                    "type": "string",
                    "minLength": 1
                  },
                  "xpath": {
                    "type": "string",
                    "minLength": 1
                  },
                  "charOffsetStart": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "charOffsetEnd": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "sourceHint": {
                    "type": "object",
                    "properties": {
                      "kind": {
                        "type": "string",
                        "const": "source"
                      },
                      "file": {
                        "type": "string",
                        "minLength": 1
                      },
                      "lineStart": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "colStart": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      },
                      "lineEnd": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "colEnd": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      }
                    },
                    "required": [
                      "kind",
                      "file",
                      "lineStart",
                      "colStart",
                      "lineEnd",
                      "colEnd"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "kind",
                  "file",
                  "xpath",
                  "charOffsetStart",
                  "charOffsetEnd"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "html-element"
                  },
                  "file": {
                    "type": "string",
                    "minLength": 1
                  },
                  "xpath": {
                    "type": "string",
                    "minLength": 1
                  },
                  "sourceHint": {
                    "type": "object",
                    "properties": {
                      "kind": {
                        "type": "string",
                        "const": "source"
                      },
                      "file": {
                        "type": "string",
                        "minLength": 1
                      },
                      "lineStart": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "colStart": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      },
                      "lineEnd": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "colEnd": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      }
                    },
                    "required": [
                      "kind",
                      "file",
                      "lineStart",
                      "colStart",
                      "lineEnd",
                      "colEnd"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "kind",
                  "file",
                  "xpath"
                ],
                "additionalProperties": false
              }
            ]
          },
          "note": {
            "default": "",
            "type": "string"
          },
          "thread": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "at": {
                  "type": "string",
                  "format": "date-time",
                  "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
                },
                "body": {
                  "type": "string"
                }
              },
              "required": [
                "at",
                "body"
              ],
              "additionalProperties": false
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
          },
          "groupId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          }
        },
        "required": [
          "id",
          "paperId",
          "category",
          "quote",
          "contextBefore",
          "contextAfter",
          "anchor",
          "note",
          "thread",
          "createdAt"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "bundleVersion",
    "tool",
    "project",
    "papers",
    "annotations"
  ],
  "additionalProperties": false
}
