    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@obelus/bundle-schema": "workspace:*"
  },
  "devDependencies": {
    "vitest": "4.1.4"
  }
