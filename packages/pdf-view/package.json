{
  "name": "@obelus/pdf-view",
  "version": "0.1.0",
  "description": "PDF.js-backed React components (document, page) for Obelus. Shared by the web app and the desktop app.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./pdf.css": "./src/pdf.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@obelus/anchor": "workspace:*",
    "@obelus/repo": "workspace:*",
    "@obelus/review-shell": "workspace:*",
    "@obelus/review-store": "workspace:*"
  },
  "peerDependencies": {
    "pdfjs-dist": "5.7.284",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "pdfjs-dist": "5.7.284",
    "react": "19.2.5",
    "vitest": "4.1.5"
  }
}
