{
  "name": "@obelus/review-store",
  "version": "0.1.0",
  "description": "Zustand-backed review state (selection, pending draft, annotations). Injected with an AnnotationsRepo — web binds Dexie, desktop binds SQLite.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@obelus/anchor": "workspace:*",
    "@obelus/bundle-schema": "workspace:*",
    "@obelus/repo": "workspace:*",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "vitest": "4.1.4"
  }
}
