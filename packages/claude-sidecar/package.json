{
  "name": "@obelus/claude-sidecar",
  "version": "0.1.0",
  "description": "Thin TS wrapper around the Tauri Rust claude_session commands. Spawns claude --print against a bundle, streams stdout/stderr, parses .obelus/plan-<ts>.json.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "vitest": "4.1.4"
  }
}
