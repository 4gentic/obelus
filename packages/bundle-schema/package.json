{
  "name": "@obelus/bundle-schema",
  "version": "0.1.0",
  "description": "The review-bundle contract shared by the Obelus web app and the Claude Code plugin.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./json-schema/v1": "./schemas/bundle-v1.schema.json",
    "./json-schema/v2": "./schemas/bundle-v2.schema.json",
    "./json-schema/project-meta": "./schemas/project-meta.schema.json",
    "./json-schema/compile-error": "./schemas/compile-error.schema.json"
  },
  "files": [
    "schemas",
    "src"
  ],
  "scripts": {
    "build": "tsx ./scripts/emit-json-schema.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "tsx": "4.21.0",
    "vitest": "4.1.4"
  }
}
